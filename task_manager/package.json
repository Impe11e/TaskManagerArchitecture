{
  "name": "task_manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/server.ts",
    "dev:ui": "vite",
    "build": "vite build",
    "start": "node dist/server/server.js",
    "build-db": "docker build -t db-image .",
    "start-db": "docker run -d -p 5433:5432 --name database --env-file .env_db db-image",
    "run-db": "docker start database",
    "stop-db": "docker stop database",
    "delete-db-container": "docker rm database",
    "test:int": "npm run run-tdb && (cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest tests/integrational --runInBand ; npm run stop-tdb)",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest tests/unit --runInBand",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vite": "^7.3.1"
  }
}
