{
  "name": "task_manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/server.ts",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "build": "tsc",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/unit --runInBand",
    "test:int": "npm run run-tdb && (cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integrational --runInBand ; npm run stop-tdb)",
    "run-tdb": "docker run -d -p 5434:5432 --name test_database --env-file .env_tpool postgres",
    "stop-tdb": "docker stop test_database && docker rm test_database"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.1"
  }
}
