{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmitOnError": false,
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution": "nodenext", 
    "target": "esnext",
    "lib": ["esnext", "dom"],
    "types": ["node"],

    "sourceMap": true,
    "declaration": false,
    
    "strict": false,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}